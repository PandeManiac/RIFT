{
    "version": "2.0.0",

    "tasks": [
        {
            "label": "CMake: Clean All",
            "type": "shell",
            "command": "cmake",
            "args": ["-E", "rm", "-rf", "${workspaceFolder}/build"],
            "presentation": { "panel": "shared", "reveal": "always" }
        },

        // ------------------------
        // Configure (sets active preset)
        // ------------------------

        {
            "label": "Linux: Configure Debug",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "export VCPKG_ROOT=\"${VCPKG_ROOT:-$HOME/vcpkg}\"; cmake --preset linux-debug --fresh -DRFT_ENABLE_ASAN=OFF && echo linux-debug > .cmake_preset && ln -sfn build/linux-debug/compile_commands.json compile_commands.json"
            ],
            "presentation": { "panel": "shared", "reveal": "always" }
        },
        {
            "label": "Linux: Configure Release",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "export VCPKG_ROOT=\"${VCPKG_ROOT:-$HOME/vcpkg}\"; cmake --preset linux-release --fresh -DRFT_ENABLE_ASAN=OFF && echo linux-release > .cmake_preset && ln -sfn build/linux-release/compile_commands.json compile_commands.json"
            ],
            "presentation": { "panel": "shared", "reveal": "always" }
        },

        {
            "label": "Windows: Configure Debug",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "export VCPKG_ROOT=\"${VCPKG_ROOT:-$HOME/vcpkg}\"; cmake --preset windows-debug --fresh -DRFT_ENABLE_ASAN=OFF && echo windows-debug > .cmake_preset && ln -sfn build/windows-debug/compile_commands.json compile_commands.json"
            ],
            "presentation": { "panel": "shared", "reveal": "always" }
        },
        {
            "label": "Windows: Configure Release",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "export VCPKG_ROOT=\"${VCPKG_ROOT:-$HOME/vcpkg}\"; cmake --preset windows-release --fresh -DRFT_ENABLE_ASAN=OFF && echo windows-release > .cmake_preset && ln -sfn build/windows-release/compile_commands.json compile_commands.json"
            ],
            "presentation": { "panel": "shared", "reveal": "always" }
        },

        // ------------------------
        // Build (uses active preset)
        // ------------------------

        {
            "label": "Linux: Build",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "cmake --build --preset $(cat .cmake_preset)"
            ],
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "panel": "shared", "reveal": "always" }
        },

        {
            "label": "Windows: Build",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "cmake --build --preset $(cat .cmake_preset)"
            ],
            "presentation": { "panel": "shared", "reveal": "always" }
        },

        // ------------------------
        // Run (build + run, same preset)
        // ------------------------

        {
            "label": "Linux: Run",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "cmake --build --preset $(cat .cmake_preset) --target run"
            ],
            "dependsOn": ["Linux: Build"],
            "group": { "kind": "test", "isDefault": true },
            "presentation": {
                "panel": "shared",
                "reveal": "always",
                "focus": true
            }
        },

        {
            "label": "Windows: Run (Wine)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "cd '${workspaceFolder}/build/$(cat .cmake_preset)' && env WINEDEBUG=-all MESA_LOG_LEVEL=error LIBGL_DEBUG=quiet wine ./RFT.exe"
            ],
            "dependsOn": ["Windows: Build"],
            "presentation": {
                "panel": "shared",
                "reveal": "always",
                "focus": true
            }
        },

        // ------------------------
        // Clean
        // ------------------------

        {
            "label": "Linux: Clean",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "cmake --build --preset $(cat .cmake_preset) --target clean"
            ],
            "presentation": { "panel": "shared", "reveal": "always" }
        }
    ]
}
